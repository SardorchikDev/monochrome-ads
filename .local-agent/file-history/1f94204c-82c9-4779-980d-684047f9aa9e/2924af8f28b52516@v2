  .work-title {
    font-size: 28px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -1px;
  }

  .work-tag {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--fg-muted);
    margin-top: 8px;
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .work-num {
    position: absolute;
    top: 32px;
    right: 32px;
    font-family: 'Space Mono', monospace;
    font-size: 64px;
    font-weight: 700;
    color: var(--border);
    transition: color 0.3s;
  }
  .work-item:hover .work-num { color: var(--fg); }

  /* ============================================
     GALLERY
   ============================================ */
  .gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
  }

  .gallery-item {
    aspect-ratio: 1;
    background: var(--bg);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s;
    cursor: pointer;
