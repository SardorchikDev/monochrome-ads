<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VOID — Design Collective</title>

<!-- SEO & Social -->
<meta name="description" content="VOID is a design collective operating at the intersection of art and technology. We believe in the power of constraint — that emptiness has weight, and silence has shape.">
<meta property="og:title" content="VOID — Design Collective">
<meta property="og:description" content="We do not add. We subtract — until only truth remains.">
<meta property="og:type" content="website">
<meta property="og:image" content="/og.jpg">
<meta name="twitter:card" content="summary_large_image">
<meta name="theme-color" content="#000">

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

<!-- Favicon (SVG data URI) -->
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='black'/><text x='50' y='68' font-family='monospace' font-size='50' fill='white' text-anchor='middle'>V</text></svg>">

<style>
  :root {
    --black: #000;
    --white: #fff;
    --gray-100: #f5f5f5;
    --gray-200: #e0e0e0;
    --gray-300: #b0b0b0;
    --gray-400: #808080;
    --gray-500: #505050;
    --gray-600: #303030;
    --gray-700: #1a1a1a;
    --gray-800: #0a0a0a;
    --bg: var(--black);
    --fg: var(--white);
    --fg-dim: var(--gray-300);
    --fg-muted: var(--gray-400);
    --border: var(--gray-700);
    --border-subtle: var(--gray-800);
  }

  [data-theme="light"] {
    --bg: var(--white);
    --fg: var(--black);
    --fg-dim: var(--gray-600);
    --fg-muted: var(--gray-500);
    --border: var(--gray-200);
    --border-subtle: var(--gray-100);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; border-radius: 0; }

  html {
    scroll-behavior: auto; /* smooth scroll handled by JS */
  }

  body {
    background: var(--bg);
    color: var(--fg);
    font-family: 'Space Grotesk', sans-serif;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    cursor: none;
    transition: background 0.6s ease, color 0.6s ease;
  }

  /* ============================================
     LOADING SCREEN
   ============================================ */
  .loader {
    position: fixed;
    inset: 0;
    background: var(--black);
    z-index: 20000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }
  .loader.done {
    opacity: 0;
    visibility: hidden;
  }
  .loader-logo {
    font-family: 'Space Mono', monospace;
    font-size: 48px;
    font-weight: 700;
    letter-spacing: 24px;
    color: var(--white);
    opacity: 0;
    animation: loaderFadeIn 0.8s ease 0.2s forwards;
  }
  .loader-count {
    font-family: 'Space Mono', monospace;
    font-size: 14px;
    color: var(--gray-500);
    margin-top: 24px;
    opacity: 0;
    animation: loaderFadeIn 0.4s ease 0.5s forwards;
  }
  .loader-bar {
    width: 200px;
    height: 1px;
    background: var(--gray-700);
    margin-top: 16px;
    position: relative;
    opacity: 0;
    animation: loaderFadeIn 0.4s ease 0.5s forwards;
  }
  .loader-bar-fill {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0%;
    background: var(--white);
    transition: width 0.1s;
  }
  .loader-tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    color: var(--gray-500);
    margin-top: 32px;
    letter-spacing: 4px;
    text-transform: uppercase;
    opacity: 0;
    max-width: 400px;
    text-align: center;
    animation: loaderFadeIn 0.6s ease 0.8s forwards;
  }

  @keyframes loaderFadeIn {
    to { opacity: 1; }
  }

  /* ============================================
     CUSTOM CURSOR SYSTEM
   ============================================ */
  .cursor-main {
    position: fixed;
    width: 12px;
    height: 12px;
    background: var(--fg);
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: difference;
    transform: translate(-50%, -50%);
    transition: width 0.2s, height 0.2s;
  }
  .cursor-main.hovering {
    width: 40px;
    height: 40px;
    border-radius: 50%;
  }

  .cursor-follower {
    position: fixed;
    width: 40px;
    height: 40px;
    border: 1px solid var(--fg);
    pointer-events: none;
    z-index: 9998;
    mix-blend-mode: difference;
    transform: translate(-50%, -50%);
    opacity: 0.5;
    transition: opacity 0.2s;
  }
  .cursor-follower.hovering {
    width: 64px;
    height: 64px;
    opacity: 0.2;
  }

  /* FOCUS VISIBILITY (accessibility) */
  :focus-visible {
    outline: 2px solid var(--fg);
    outline-offset: 4px;
  }

  /* ============================================
     GRAIN OVERLAY
   ============================================ */
  .grain-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9990;
    opacity: 0.04;
    mix-blend-mode: multiply;
  }

  .scanlines {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9989;
    opacity: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
    transition: opacity 0.6s;
  }
  .scanlines.visible {
    opacity: 1;
  }

  /* ============================================
     PAGE TRANSITION (clip-path)
   ============================================ */
  .page-transition {
    position: fixed;
    inset: 0;
    background: var(--fg);
    z-index: 10000;
    clip-path: circle(0% at var(--cx, 50%) var(--cy, 50%));
    pointer-events: none;
    transition: clip-path 0.7s cubic-bezier(0.65, 0, 0.35, 1);
  }
  .page-transition.wiping {
    clip-path: circle(150% at var(--cx, 50%) var(--cy, 50%));
  }
  .page-transition.wiping-out {
    clip-path: circle(150% at var(--cx, 50%) var(--cy, 50%));
    transition: clip-path 0.5s cubic-bezier(0.65, 0, 0.35, 1);
  }
  .page-transition.out {
    clip-path: circle(0% at var(--cx, 50%) var(--cy, 50%));
  }

  /* ============================================
     NAVIGATION
   ============================================ */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 40px;
    z-index: 200;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    transition: all 0.4s ease;
    cursor: none;
  }

  .logo {
    font-family: 'Space Mono', monospace;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 8px;
    text-transform: uppercase;
    color: var(--fg);
    text-decoration: none;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    transition: color 0.2s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--fg);
    transition: width 0.3s ease;
  }
  .nav-links a:hover { color: var(--fg); }
  .nav-links a:hover::after { width: 100%; }

  .theme-toggle {
    background: none;
    border: 1px solid var(--border);
    color: var(--fg);
    padding: 8px 16px;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
  }
  .theme-toggle:hover {
    background: var(--fg);
    color: var(--bg);
  }

  /* ============================================
     SCROLL ANIMATIONS (IntersectionObserver)
   ============================================ */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }

  .reveal-left {
    opacity: 0;
    transform: translateX(-60px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal-left.revealed {
    opacity: 1;
    transform: translateX(0);
  }

  .reveal-right {
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal-right.revealed {
    opacity: 1;
    transform: translateX(0);
  }

  .reveal-scale {
    opacity: 0;
    transform: scale(0.9);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal-scale.revealed {
    opacity: 1;
    transform: scale(1);
  }

  /* ============================================
     HERO SECTION
   ============================================ */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 80px;
    position: relative;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .hero-tag {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .hero-tag::before {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--fg-muted);
  }

  .hero-title-wrap {
    position: relative;
    mix-blend-mode: difference;
  }

  .hero-title {
    font-size: clamp(60px, 10vw, 140px);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -4px;
    text-transform: uppercase;
    max-width: 900px;
    color: var(--fg);
  }
  .hero-title .outline {
    color: var(--bg);
    -webkit-text-stroke: 2px var(--fg);
    text-stroke: 2px var(--fg);
  }

  .kinetic-letter {
    display: inline-block;
    transition: transform 0.15s ease;
    will-change: transform;
  }

  .hero-desc {
    max-width: 420px;
    margin-top: 48px;
    font-size: 16px;
    line-height: 1.6;
    color: var(--fg-dim);
    font-weight: 300;
  }

  .hero-cta {
    margin-top: 56px;
    display: inline-block;
    padding: 16px 48px;
    background: var(--fg);
    color: var(--bg);
    text-decoration: none;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 4px;
    text-transform: uppercase;
    font-weight: 700;
    transition: all 0.2s;
    border: 2px solid var(--fg);
  }
  .hero-cta:hover {
    background: var(--bg);
    color: var(--fg);
  }

  /* DECORATIVE GRID */
  .grid-overlay {
    position: absolute;
    right: 80px;
    bottom: 80px;
    display: grid;
    grid-template-columns: repeat(4, 60px);
    grid-template-rows: repeat(4, 60px);
    gap: 1px;
  }
  .grid-cell {
    border: 1px solid var(--border);
    background: var(--bg);
    transition: background 0.3s, border-color 0.3s;
  }
  .grid-cell.active {
    background: var(--fg);
  }
  .grid-cell:hover {
    border-color: var(--fg);
  }

  /* ============================================
     VERTICAL TEXT ELEMENT
   ============================================ */
  .vertical-text {
    position: absolute;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: var(--fg-muted);
    opacity: 0.5;
  }
  .vertical-text.left {
    left: 20px;
    top: 50%;
    transform: rotate(-90deg);
    transform-origin: 0 0;
  }
  .vertical-text.right {
    right: 20px;
    top: 50%;
    transform: rotate(90deg);
    transform-origin: 0 0;
  }

  /* ============================================
     STATEMENT SECTION
   ============================================ */
  .statement {
    padding: 160px 80px;
    text-align: center;
    position: relative;
    background: var(--fg);
    color: var(--bg);
  }

  .statement-text {
    font-size: clamp(32px, 6vw, 80px);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.05;
    letter-spacing: -3px;
    max-width: 1000px;
    margin: 0 auto;
    mix-blend-mode: difference;
    color: inherit;
  }

  .statement-author {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-top: 64px;
  }

  .quote-marks {
    font-size: 120px;
    font-family: 'Space Mono', monospace;
    position: absolute;
    top: 20px;
    left: 80px;
    color: var(--fg);
    opacity: 0.1;
    line-height: 1;
  }

  /* ============================================
     MARQUEE
   ============================================ */
  .marquee-section {
    padding: 40px 0;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .marquee {
    display: flex;
    gap: 48px;
    animation: marquee 20s linear infinite;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .marquee-item {
    font-size: 72px;
    font-weight: 700;
    text-transform: uppercase;
    white-space: nowrap;
    letter-spacing: -2px;
    color: var(--border);
  }
  .marquee-item .dot {
    display: inline-block;
    width: 12px;
    height: 12px;
    background: var(--fg);
    margin: 0 32px;
    vertical-align: middle;
  }

  /* ============================================
     STATS
   ============================================ */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: var(--bg);
  }

  .stat {
    padding: 64px 48px;
    border-right: 1px solid var(--border);
    text-align: center;
    transition: background 0.3s;
  }
  .stat:last-child { border-right: none; }
  .stat:hover { background: var(--gray-700); }
  [data-theme="light"] .stat:hover { background: var(--gray-100); }

  .stat-value {
    font-family: 'Space Mono', monospace;
    font-size: 56px;
    font-weight: 700;
    letter-spacing: -2px;
    margin-bottom: 12px;
  }

  .stat-label {
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  /* ============================================
     SECTION COMMON
   ============================================ */
  .section {
    padding: 80px;
    border-bottom: 1px solid var(--border);
  }

  .section-header {
    margin-bottom: 64px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 16px;
  }

  .section-title {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -2px;
  }

  .section-count {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--fg-muted);
    letter-spacing: 2px;
  }

  /* ============================================
     MANIFESTO SECTION (NEW)
   ============================================ */
  .manifesto {
    padding: 160px 80px;
    position: relative;
  }

  .manifesto-content {
    max-width: 800px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
  }

  .manifesto-text {
    font-size: 18px;
    line-height: 1.8;
    color: var(--fg-dim);
    font-weight: 300;
  }

  .manifesto-text p {
    margin-bottom: 24px;
  }

  .manifesto-text strong {
    color: var(--fg);
    font-weight: 600;
  }

  .manifesto-rules {
    padding-top: 8px;
  }

  .manifesto-rule {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 2px;
    color: var(--fg-muted);
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s;
  }
  .manifesto-rule:hover {
    color: var(--fg);
    padding-left: 12px;
  }
  .manifesto-rule:first-child {
    border-top: 1px solid var(--border);
  }

  /* ============================================
     FEATURES / PRINCIPLES
   ============================================ */
  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
  }

  .feature {
    padding: 48px;
    background: var(--bg);
    transition: background 0.3s, color 0.3s;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }
  .feature::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--fg);
    transform: translateY(100%);
    transition: transform 0.4s ease;
    z-index: 0;
  }
  .feature:hover::before {
    transform: translateY(0%);
  }
  .feature:hover {
    color: var(--bg);
  }
  .feature > * {
    position: relative;
    z-index: 1;
  }

  .feature-number {
    font-family: 'Space Mono', monospace;
    font-size: 72px;
    font-weight: 700;
    color: var(--border);
    line-height: 1;
    margin-bottom: 32px;
    transition: color 0.3s;
  }
  .feature:hover .feature-number {
    color: var(--fg);
  }

  .feature-title {
    font-size: 20px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 16px;
  }

  .feature-desc {
    font-size: 14px;
    line-height: 1.7;
    color: var(--fg-dim);
    font-weight: 300;
    transition: color 0.3s;
  }
  .feature:hover .feature-desc {
    color: var(--fg);
  }

  /* ============================================
     HORIZONTAL WORK SCROLL (NEW)
   ============================================ */
  .work-horizontal {
    padding: 80px 0;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .work-horizontal .section-header {
    padding: 0 80px;
    margin-bottom: 48px;
  }

  .work-scroll-track {
    display: flex;
    gap: 32px;
    padding: 0 80px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -ms-overflow-style: none;
    scrollbar-width: none;
    cursor: grab;
  }
  .work-scroll-track::-webkit-scrollbar { display: none; }
  .work-scroll-track.dragging { cursor: grabbing; }

  .work-scroll-card {
    min-width: 500px;
    height: 400px;
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    scroll-snap-align: start;
    position: relative;
    overflow: hidden;
    transition: all 0.3s;
    cursor: pointer;
  }
  .work-scroll-card:hover {
    border-color: var(--fg);
  }

  .work-card-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.08;
    transition: opacity 0.3s;
  }
  .work-scroll-card:hover .work-card-pattern {
    opacity: 0.15;
  }

  .work-card-pattern.pattern-1 {
    background:
      repeating-linear-gradient(0deg, var(--fg) 0px, var(--fg) 1px, transparent 1px, transparent 24px),
      repeating-linear-gradient(90deg, var(--fg) 0px, var(--fg) 1px, transparent 1px, transparent 24px);
  }
  .work-card-pattern.pattern-2 {
    background:
      repeating-conic-gradient(var(--fg) 0% 25%, transparent 25% 50%) 0 0 / 40px 40px;
  }
  .work-card-pattern.pattern-3 {
    background:
      repeating-linear-gradient(45deg, var(--fg) 0px, var(--fg) 1px, transparent 1px, transparent 16px);
  }
  .work-card-pattern.pattern-4 {
    background:
      radial-gradient(circle at 10px 10px, var(--fg) 1px, transparent 1px) 0 0 / 20px 20px;
  }
  .work-card-pattern.pattern-5 {
    background:
      repeating-linear-gradient(90deg, var(--fg) 0px, var(--fg) 2px, transparent 2px, transparent 20px),
      repeating-linear-gradient(0deg, var(--fg) 0px, var(--fg) 1px, transparent 1px, transparent 40px);
  }

  .work-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .work-card-num {
    font-family: 'Space Mono', monospace;
    font-size: 64px;
    font-weight: 700;
    color: var(--border);
    line-height: 1;
    transition: color 0.3s;
  }
  .work-scroll-card:hover .work-card-num {
    color: var(--fg);
    opacity: 0.3;
  }

  .work-card-year {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--fg-muted);
    letter-spacing: 2px;
  }

  .work-card-bottom h3 {
    font-size: 28px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -1px;
    margin-bottom: 8px;
  }
  .work-card-bottom p {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--fg-muted);
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .work-card-arrow {
    position: absolute;
    right: 40px;
    bottom: 40px;
    font-size: 24px;
    opacity: 0;
    transform: translate(-8px, 8px);
