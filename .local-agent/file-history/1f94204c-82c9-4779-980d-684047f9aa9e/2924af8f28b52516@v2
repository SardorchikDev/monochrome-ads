  .gallery-item:hover { background: var(--gray-600); }

  .gallery-pattern {
    position: absolute;
    inset: 0;
    transition: opacity 0.3s;
  }
  .gallery-item:hover .gallery-pattern { opacity: 0.3; }

  .gallery-item:nth-child(1) .gallery-pattern {
    background: repeating-linear-gradient(0deg, var(--fg) 0px, var(--fg) 2px, transparent 2px, transparent 12px);
    opacity: 0.15;
  }
  .gallery-item:nth-child(2) .gallery-pattern {
    background: repeating-linear-gradient(45deg, var(--fg) 0px, var(--fg) 1px, transparent 1px, transparent 8px);
    opacity: 0.15;
  }
  .gallery-item:nth-child(3) .gallery-pattern {
    background: repeating-conic-gradient(var(--fg) 0% 25%, transparent 25% 50%) 0 0 / 30px 30px;
    opacity: 0.1;
  }
  .gallery-item:nth-child(4) .gallery-pattern {
    background: repeating-linear-gradient(90deg, var(--fg) 0px, var(--fg) 2px, transparent 2px, transparent 6px);
    opacity: 0.15;
  }

  .gallery-label {
    position: relative;
    z-index: 1;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 6px;
    text-transform: uppercase;
    padding: 12px 24px;
    background: var(--bg);
    border: 1px solid var(--fg);
    color: var(--fg);
    transition: all 0.3s;
  }
  .gallery-item:hover .gallery-label {
    background: var(--fg);
    color: var(--bg);
  }

  /* ============================================
     TEAM SECTION
   ============================================ */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
  }

  .team-member {
    background: var(--bg);
    padding: 40px 32px;
    text-align: center;
    transition: background 0.3s;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }
  .team-member:hover { background: var(--gray-600); }

  .team-portrait {
    width: 100%;
    aspect-ratio: 1;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
  }

  .portrait-placeholder {
    width: 100%;
    height: 100%;
    background: var(--gray-700);
    transition: transform 0.4s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    font-weight: 700;
    font-family: 'Space Mono', monospace;
    color: var(--fg);
    opacity: 0.3;
  }
  [data-theme="light"] .portrait-placeholder { background: var(--gray-100); opacity: 0.5; }
  .team-member:hover .portrait-placeholder { transform: scale(1.05); }

  .team-name {
    font-size: 16px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  .team-role {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  /* ============================================
     TIMELINE
   ============================================ */
  .timeline {
    position: relative;
    padding-left: 80px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--border);
  }

  .timeline-item {
    position: relative;
    padding: 48px 0;
    border-bottom: 1px solid var(--border);
  }
  .timeline-item:last-child { border-bottom: none; }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -84px;
    top: 56px;
    width: 8px;
    height: 8px;
    background: var(--fg);
    transition: transform 0.2s;
  }
  .timeline-item:hover::before {
