  }

  .timeline-year {
    font-family: 'Space Mono', monospace;
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .timeline-title {
    font-size: 24px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }

  .timeline-desc {
