    color: var(--fg-dim);
    line-height: 1.6;
    max-width: 600px;
  }

  /* ============================================
     CONTACT SECTION (NEW)
   ============================================ */
  #contact {
    padding: 80px;
    border-top: 1px solid var(--border);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
