    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 8px;
    font-weight: 500;
  }

  .contact-info-item a,
  .contact-info-item p {
    color: var(--fg-dim);
    text-decoration: none;
    font-size: 16px;
    transition: color 0.2s;
  }
  .contact-info-item a:hover {
    color: var(--fg);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form-group {
    position: relative;
  }

  .form-group label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--fg-muted);
    display: block;
    margin-bottom: 8px;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg);
    padding: 14px 16px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    transition: border-color 0.2s;
    outline: none;
    cursor: none;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--fg);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    align-self: flex-start;
    padding: 14px 40px;
    background: var(--fg);
    color: var(--bg);
    border: 2px solid var(--fg);
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 4px;
    text-transform: uppercase;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }
  .form-submit:hover {
    background: var(--bg);
    color: var(--fg);
  }

  .form-success {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    color: var(--fg-muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0;
    transition: opacity 0.3s;
    text-align: center;
  }
  .form-success.visible {
    opacity: 1;
  }

  /* ============================================
     PROJECT MODAL (NEW)
   ============================================ */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    z-index: 5000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s, visibility 0.4s;
  }
  .modal-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .modal-content {
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--border);
    max-width: 800px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    position: relative;
    transform: translateY(20px) scale(0.97);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .modal-overlay.active .modal-content {
    transform: translateY(0) scale(1);
  }

  .modal-close {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 40px;
    height: 40px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg);
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    z-index: 1;
  }
  .modal-close:hover {
    background: var(--fg);
    color: var(--bg);
  }

  .modal-header {
    padding: 48px 48px 32px;
    border-bottom: 1px solid var(--border);
  }

  .modal-header-meta {
    display: flex;
    gap: 24px;
    margin-bottom: 16px;
  }

  .modal-header-meta span {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .modal-header h2 {
    font-size: 36px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -2px;
  }

  .modal-preview {
    height: 200px;
    position: relative;
    overflow: hidden;
  }

  .modal-body {
    padding: 32px 48px 48px;
  }

  .modal-body p {
    font-size: 15px;
    line-height: 1.8;
    color: var(--fg-dim);
    font-weight: 300;
    margin-bottom: 16px;
  }

  .modal-body ul {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 24px;
  }

  .modal-body ul li {
    font-size: 13px;
    color: var(--fg-muted);
    padding: 12px 16px;
    border: 1px solid var(--border);
    letter-spacing: 1px;
  }

  /* ============================================
     FOOTER
   ============================================ */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 64px;
  }

  .footer-brand {
    font-family: 'Space Mono', monospace;
    font-size: 24px;
    letter-spacing: 8px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .footer-copy {
    font-size: 13px;
    color: var(--fg-muted);
    font-weight: 300;
  }

  .footer-col-title {
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 20px;
    font-weight: 500;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-links a {
    color: var(--fg-dim);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--fg); }

  /* ============================================
     SMOOTH SCROLL CONTAINER
   ============================================ */
  .smooth-wrapper {
