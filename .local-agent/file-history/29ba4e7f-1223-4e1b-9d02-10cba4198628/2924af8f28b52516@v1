<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VOID — Design Collective</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap');

  :root {
    --black: #000;
    --white: #fff;
    --gray-100: #f5f5f5;
    --gray-200: #e0e0e0;
    --gray-300: #b0b0b0;
    --gray-400: #808080;
    --gray-500: #505050;
    --gray-600: #303030;
    --gray-700: #1a1a1a;
    --gray-800: #0a0a0a;
    --bg: var(--black);
    --fg: var(--white);
    --fg-dim: var(--gray-300);
    --fg-muted: var(--gray-400);
    --border: var(--gray-700);
    --border-subtle: var(--gray-800);
  }

  [data-theme="light"] {
    --bg: var(--white);
    --fg: var(--black);
    --fg-dim: var(--gray-600);
    --fg-muted: var(--gray-500);
    --border: var(--gray-200);
    --border-subtle: var(--gray-100);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; border-radius: 0; }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: var(--bg);
    color: var(--fg);
    font-family: 'Space Grotesk', sans-serif;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    cursor: none;
    transition: background 0.6s ease, color 0.6s ease;
  }

  /* ============================================
     CUSTOM CURSOR SYSTEM
   ============================================ */
  .cursor-main {
    position: fixed;
    width: 12px;
    height: 12px;
    background: var(--fg);
    pointer-events: none;
    z-index: 9999;
    mix-blend-mode: difference;
    transform: translate(-50%, -50%);
    transition: width 0.2s, height 0.2s, border-radius 0.1s;
  }
  .cursor-main.hovering {
    width: 32px;
    height: 32px;
  }

  .cursor-follower {
    position: fixed;
    width: 40px;
    height: 40px;
    border: 1px solid var(--fg);
    pointer-events: none;
    z-index: 9998;
    mix-blend-mode: difference;
    transform: translate(-50%, -50%);
    opacity: 0.5;
  }
  .cursor-follower.hovering {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  /* ============================================
     GRAIN OVERLAY
   ============================================ */
  .grain-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9990;
    opacity: 0.04;
    mixture: blend-mode: multiply;
  }
  .grain-overlay canvas {
    width: 100%;
    height: 100%;
  }

  .scanlines {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9989;
    opacity: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 2px,
      rgba(0,0,0,0.03) 2px,
      rgba(0,0,0,0.03) 4px
    );
    transition: opacity 0.6s;
  }
  .scanlines.visible {
    opacity: 1;
  }

  /* ============================================
     PAGE TRANSITION
   ============================================ */
  .page-transition {
    position: fixed;
    inset: 0;
    background: var(--fg);
    z-index: 10000;
    transform: translateY(100%);
    pointer-events: none;
  }
  .page-transition.wiping {
    animation: pageWipe 0.8s ease-in-out;
  }
  @keyframes pageWipe {
    0% { transform: translateY(100%); }
    40% { transform: translateY(0%); }
    60% { transform: translateY(0%); }
    100% { transform: translateY(-100%); }
  }

  /* ============================================
     NAVIGATION
   ============================================ */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 40px;
    z-index: 200;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    transition: all 0.4s ease;
    cursor: none;
  }

  .logo {
    font-family: 'Space Mono', monospace;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 8px;
    text-transform: uppercase;
    color: var(--fg);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: uppercase;
    transition: color 0.2s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--fg);
    transition: width 0.3s ease;
  }
  .nav-links a:hover { color: var(--fg); }
  .nav-links a:hover::after { width: 100%; }

  .theme-toggle {
    background: none;
    border: 1px solid var(--border);
    color: var(--fg);
    padding: 8px 16px;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }
  .theme-toggle:hover {
    background: var(--fg);
    color: var(--bg);
  }

  /* ============================================
     SCROLL ANIMATIONS
   ============================================ */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }

  .reveal-left {
    opacity: 0;
    transform: translateX(-60px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal-left.revealed {
    opacity: 1;
    transform: translateX(0);
  }

  .reveal-right {
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal-right.revealed {
    opacity: 1;
    transform: translateX(0);
  }

  .reveal-scale {
    opacity: 0;
    transform: scale(0.9);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal-scale.revealed {
    opacity: 1;
    transform: scale(1);
  }

  /* ============================================
     HERO SECTION
   ============================================ */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 80px;
    position: relative;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .hero-tag {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .hero-tag::before {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--fg-muted);
  }

  .hero-title-wrap {
    position: relative;
    mix-blend-mode: difference;
  }

  .hero-title {
    font-size: clamp(60px, 10vw, 140px);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -4px;
    text-transform: uppercase;
    max-width: 900px;
    color: var(--fg);
  }
  .hero-title .outline {
    color: var(--bg);
    -webkit-text-stroke: 2px var(--fg);
    text-stroke: 2px var(--fg);
  }

  .kinetic-letter {
    display: inline-block;
    transition: transform 0.15s ease;
    will-change: transform;
  }

  .hero-desc {
    max-width: 420px;
    margin-top: 48px;
    font-size: 16px;
    line-height: 1.6;
    color: var(--fg-dim);
    font-weight: 300;
  }

  .hero-cta {
    margin-top: 56px;
    display: inline-block;
    padding: 16px 48px;
    background: var(--fg);
    color: var(--bg);
    text-decoration: none;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 4px;
    text-transform: uppercase;
    font-weight: 700;
    transition: all 0.2s;
    border: 2px solid var(--fg);
  }
  .hero-cta:hover {
    background: var(--bg);
    color: var(--fg);
  }

  /* DECORATIVE GRID */
  .grid-overlay {
    position: absolute;
    right: 80px;
    bottom: 80px;
    display: grid;
    grid-template-columns: repeat(4, 60px);
    grid-template-rows: repeat(4, 60px);
    gap: 1px;
  }
  .grid-cell {
    border: 1px solid var(--border);
    background: var(--bg);
    transition: background 0.3s, border-color 0.3s;
  }
  .grid-cell.active {
    background: var(--fg);
  }
  .grid-cell:hover {
    border-color: var(--fg);
  }

  /* ============================================
     VERTICAL TEXT ELEMENT
   ============================================ */
  .vertical-text {
    position: absolute;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: var(--fg-muted);
    opacity: 0.5;
  }
  .vertical-text.left {
    left: 20px;
    top: 50%;
    transform: rotate(-90deg);
    transform-origin: 0 0;
  }
  .vertical-text.right {
    right: 20px;
    top: 50%;
    transform: rotate(90deg);
    transform-origin: 0 0;
  }

  /* ============================================
     STATEMENT SECTION
   ============================================ */
  .statement {
    padding: 160px 80px;
    text-align: center;
    position: relative;
    background: var(--fg);
    color: var(--bg);
  }

  .statement-text {
    font-size: clamp(32px, 6vw, 80px);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.05;
    letter-spacing: -3px;
    max-width: 1000px;
    margin: 0 auto;
    mix-blend-mode: difference;
    color: inherit;
  }

  .statement-author {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-top: 64px;
  }

  .quote-marks {
    font-size: 120px;
    font-family: 'Space Mono', monospace;
    position: absolute;
    top: 20px;
    left: 80px;
    color: var(--fg);
    opacity: 0.1;
    line-height: 1;
  }

  /* ============================================
     MARQUEE
   ============================================ */
  .marquee-section {
    padding: 40px 0;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .marquee {
    display: flex;
    gap: 48px;
    animation: marquee 20s linear infinite;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .marquee-item {
    font-size: 72px;
    font-weight: 700;
    text-transform: uppercase;
    white-space: nowrap;
    letter-spacing: -2px;
    color: var(--border);
  }
  .marquee-item .dot {
    display: inline-block;
    width: 12px;
    height: 12px;
    background: var(--fg);
    margin: 0 32px;
    vertical-align: middle;
  }

  /* ============================================
     STATS
   ============================================ */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: var(--bg);
  }

  .stat {
    padding: 64px 48px;
    border-right: 1px solid var(--border);
    text-align: center;
    transition: background 0.3s;
  }
  .stat:last-child { border-right: none; }
  .stat:hover { background: var(--gray-700); }
  [data-theme="light"] .stat:hover { background: var(--gray-100); }

  .stat-value {
    font-family: 'Space Mono', monospace;
    font-size: 56px;
    font-weight: 700;
    letter-spacing: -2px;
    margin-bottom: 12px;
  }

  .stat-label {
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  /* ============================================
     SECTION COMMON
   ============================================ */
  .section {
    padding: 80px;
    border-bottom: 1px solid var(--border);
  }

  .section-header {
    margin-bottom: 64px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 16px;
  }

  .section-title {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -2px;
  }

  .section-count {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--fg-muted);
    letter-spacing: 2px;
  }

  /* ============================================
     FEATURES
   ============================================ */
  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
  }

  .feature {
    padding: 48px;
    background: var(--bg);
    transition: background 0.3s, color 0.3s;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }
  .feature::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--fg);
    transform: translateY(100%);
    transition: transform 0.4s ease;
    z-index: 0;
  }
  .feature:hover::before {
    transform: translateY(0%);
  }
  .feature:hover {
    color: var(--bg);
  }
  .feature > * {
    position: relative;
    z-index: 1;
  }

  .feature-number {
    font-family: 'Space Mono', monospace;
    font-size: 72px;
    font-weight: 700;
    color: var(--border);
    line-height: 1;
    margin-bottom: 32px;
    transition: color 0.3s;
  }
  .feature:hover .feature-number {
    color: var(--fg);
  }

  .feature-title {
    font-size: 20px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 16px;
  }

  .feature-desc {
    font-size: 14px;
    line-height: 1.7;
    color: var(--fg-dim);
    font-weight: 300;
    transition: color 0.3s;
  }
  .feature:hover .feature-desc {
    color: var(--fg);
  }

  /* ============================================
     WORK/PROJECTS SECTION
   ============================================ */
  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
  }

  .work-item {
    aspect-ratio: 4/3;
    background: var(--bg);
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 32px;
    overflow: hidden;
    cursor: pointer;
    transition: background 0.3s;
  }
  .work-item:hover { background: var(--gray-600); }

  .work-preview {
    position: absolute;
    inset: 32px;
    bottom: 100px;
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .work-item:hover .work-preview { opacity: 1; }

  .work-preview-inner {
    width: 100%;
    height: 100%;
    background: var(--gray-600);
    overflow: hidden;
  }
  [data-theme="light"] .work-preview-inner { background: var(--gray-100); }

  .work-preview-grid {
    width: 100%;
    height: 100%;
    background-size: 20px 20px;
    background-image:
      linear-gradient(to right, var(--bg) 1px, transparent 1px),
      linear-gradient(to bottom, var(--bg) 1px, transparent 1px);
    opacity: 0.2;
  }

  .work-year {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--fg-muted);
    margin-bottom: 8px;
  }

  .work-title {
    font-size: 28px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -1px;
  }

  .work-tag {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--fg-muted);
    margin-top: 8px;
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .work-num {
    position: absolute;
    top: 32px;
    right: 32px;
    font-family: 'Space Mono', monospace;
    font-size: 64px;
    font-weight: 700;
    color: var(--border);
    transition: color 0.3s;
  }
  .work-item:hover .work-num { color: var(--fg); }

  /* ============================================
     GALLERY
   ============================================ */
  .gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
  }

  .gallery-item {
    aspect-ratio: 1;
    background: var(--bg);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s;
    cursor: pointer;
  }
  .gallery-item:hover { background: var(--gray-600); }

  .gallery-pattern {
    position: absolute;
    inset: 0;
    transition: opacity 0.3s;
  }
  .gallery-item:hover .gallery-pattern { opacity: 0.3; }

  .gallery-item:nth-child(1) .gallery-pattern {
    background: repeating-linear-gradient(0deg, var(--fg) 0px, var(--fg) 2px, transparent 2px, transparent 12px);
    opacity: 0.15;
  }
  .gallery-item:nth-child(2) .gallery-pattern {
    background: repeating-linear-gradient(45deg, var(--fg) 0px, var(--fg) 1px, transparent 1px, transparent 8px);
    opacity: 0.15;
  }
  .gallery-item:nth-child(3) .gallery-pattern {
    background: repeating-conic-gradient(var(--fg) 0% 25%, transparent 25% 50%) 0 0 / 30px 30px;
    opacity: 0.1;
  }
  .gallery-item:nth-child(4) .gallery-pattern {
    background: repeating-linear-gradient(90deg, var(--fg) 0px, var(--fg) 2px, transparent 2px, transparent 6px);
    opacity: 0.15;
  }

  .gallery-label {
    position: relative;
    z-index: 1;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 6px;
    text-transform: uppercase;
    padding: 12px 24px;
    background: var(--bg);
    border: 1px solid var(--fg);
    color: var(--fg);
    transition: all 0.3s;
  }
  .gallery-item:hover .gallery-label {
    background: var(--fg);
    color: var(--bg);
  }

  /* ============================================
     TEAM SECTION
   ============================================ */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
  }

  .team-member {
    background: var(--bg);
    padding: 40px 32px;
    text-align: center;
    transition: background 0.3s;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }
  .team-member:hover { background: var(--gray-600); }

  .team-portrait {
    width: 100%;
    aspect-ratio: 1;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
  }

  .portrait-placeholder {
    width: 100%;
    height: 100%;
    background: var(--gray-700);
    transition: transform 0.4s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    font-weight: 700;
    font-family: 'Space Mono', monospace;
    color: var(--fg);
    opacity: 0.3;
  }
  [data-theme="light"] .portrait-placeholder { background: var(--gray-100); opacity: 0.5; }
  .team-member:hover .portrait-placeholder { transform: scale(1.05); }

  .team-name {
    font-size: 16px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  .team-role {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  /* ============================================
     TIMELINE
   ============================================ */
  .timeline {
    position: relative;
    padding-left: 80px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--border);
  }

  .timeline-item {
    position: relative;
    padding: 48px 0;
    border-bottom: 1px solid var(--border);
  }
  .timeline-item:last-child { border-bottom: none; }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -84px;
    top: 56px;
    width: 8px;
    height: 8px;
    background: var(--fg);
    transition: transform 0.2s;
  }
  .timeline-item:hover::before {
    transform: scale(1.5);
  }

  .timeline-year {
    font-family: 'Space Mono', monospace;
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .timeline-title {
    font-size: 24px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }

  .timeline-desc {
    font-size: 14px;
    color: var(--fg-dim);
    line-height: 1.6;
    max-width: 600px;
  }

  /* ============================================
     FOOTER
   ============================================ */
  footer {
    padding: 80px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 64px;
    border-top: 1px solid var(--border);
    position: relative;
  }

  .footer-brand {
    font-family: 'Space Mono', monospace;
    font-size: 24px;
    letter-spacing: 8px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .footer-copy {
    font-size: 13px;
    color: var(--fg-muted);
    font-weight: 300;
  }

  .footer-col-title {
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 20px;
    font-weight: 500;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-links a {
    color: var(--fg-dim);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s;
  }
